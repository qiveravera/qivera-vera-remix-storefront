# Shopify Storefront API Configuration
# Obtenez ces valeurs depuis votre admin Shopify :
# 1. Allez dans Settings > Apps and sales channels
# 2. Développez 'Develop apps' > Create an app
# 3. Configurez l'app avec Storefront API access
# 4. Copiez votre Storefront Access Token

# Votre domaine Shopify (sans .myshopify.com)
# Exemple: qiveravera ou qivera-vera-store
SHOPIFY_STORE_DOMAIN=votre-boutique.myshopify.com

# Votre Storefront API Access Token
SHOPIFY_STOREFRONT_ACCESS_TOKEN=votre_storefront_access_token_ici
